{
  "name": "local-austin-mcp",
  "version": "0.17.1",
  "description": "Your AI's local guide to Austin: answer property, relocation, and civic questions (who's my water provider, schools, special-district taxes, flood zone, what's for sale) from authoritative Austin + Travis/Williamson/Hays County sources. No API keys.",
  "main": "index.js",
  "type": "module",
  "bin": {
    "local-austin-mcp": "index.js"
  },
  "files": [
    "index.js",
    "lib/",
    "tools/",
    "config/",
    "resources/",
    "README.md",
    "LICENSE",
    "NOTICE",
    "TRADEMARK.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "prepublishOnly": "npm run test:unit",
    "test": "node --test test/unit/*.test.js",
    "test:handshake": "node test/mcp-handshake.js",
    "test:contract": "node test/mcp-all-tools.js",
    "test:unit": "node --test test/unit/*.test.js",
    "test:smoke:tcad": "node test/smoke-tcad.js",
    "test:smoke:permits": "node test/smoke-permits.js",
    "test:smoke:code": "node test/smoke-code-cases.js",
    "test:smoke:311": "node test/smoke-311.js",
    "test:smoke:crime": "node test/smoke-crime.js",
    "test:smoke:zoning": "node test/smoke-zoning.js",
    "test:smoke:tax": "node test/smoke-tax.js",
    "test:smoke:tea": "node test/smoke-tea.js",
    "test:smoke:mud": "node test/smoke-mud-pid.js",
    "test:smoke:flood": "node test/smoke-flood.js",
    "test:smoke:p360": "node test/smoke-property360.js",
    "test:smoke:wcad": "node test/smoke-wcad.js",
    "test:smoke:hcad": "node test/smoke-hcad.js",
    "test:smoke": "node test/smoke-tcad.js && node test/smoke-permits.js && node test/smoke-code-cases.js && node test/smoke-311.js && node test/smoke-crime.js && node test/smoke-zoning.js && node test/smoke-tax.js && node test/smoke-tea.js && node test/smoke-mud-pid.js && node test/smoke-flood.js && node test/smoke-property360.js && node test/smoke-wcad.js && node test/smoke-hcad.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "claude-desktop",
    "anthropic",
    "llm-tools",
    "ai-tools",
    "austin",
    "austin-texas",
    "travis-county",
    "williamson-county",
    "hays-county",
    "texas",
    "civic-data",
    "open-data",
    "socrata",
    "gis",
    "real-estate",
    "mls",
    "property-data",
    "tcad",
    "permits",
    "zoning",
    "flood-zone",
    "schools"
  ],
  "author": "Ed Neuhaus / Neuhaus Realty Group LLC",
  "license": "Apache-2.0",
  "homepage": "https://github.com/mindwear-capitian/local-austin-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mindwear-capitian/local-austin-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mindwear-capitian/local-austin-mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
